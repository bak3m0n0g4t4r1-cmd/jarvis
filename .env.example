# Шаблон локальных настроек «Джарвиса». Скопируй в .env и при необходимости заполни:
#   cp .env.example .env
# Секретов больше нет (облако удалено) — .env НЕ обязателен. Все параметры имеют
# разумные дефолты в config.py. Файл нужен лишь для переопределения под машину.
# Сервисы systemd подхватывают .env через EnvironmentFile (см. cli.py/юниты);
# при ручном запуске экспортируйте нужные переменные в окружение сами.

# --- Распознавание команд (матчер: правила + ONNX-эмбеддинги) ---

# Порог слоя ПРАВИЛ (difflib ratio 0–1): ниже — фраза не считается совпавшей с
# синонимом команды. Выше — строже (меньше ложных срабатываний, но и пропусков больше).
# JARVIS_MATCHER_FUZZY_THRESHOLD=0.7

# Порог слоя ЭМБЕДДИНГОВ (косинус 0–1): ниже — семантический поиск не уверен → переспрос.
# JARVIS_MATCHER_EMB_THRESHOLD=0.6

# Минимальный отрыв лучшего кандидата от второго (косинус). Меньше — кандидаты почти
# равны (часто антонимы вкл/выкл) → не угадываем, лучше переспросить.
# JARVIS_MATCHER_EMB_MARGIN=0.04

# --- Отказоустойчивость и логи (у всех есть разумные дефолты — можно не задавать) ---

# Порог логирования: INFO (дефолт) — чисто и по-человечески; DEBUG — со стек-трассами
# ожидаемых сбоёв (для разбора). Уровни видны во всех сервисах одинаково.
# JARVIS_LOG_LEVEL=INFO

# Heartbeat: раз в столько секунд сервис пишет в лог, что жив (INFO). 0 — выключить.
# JARVIS_HEARTBEAT_INTERVAL=300

# Автопереподключение к MQTT: backoff между попытками, секунды (потолок мал намеренно —
# чтобы после спящего режима/перезапуска брокера Джарвис восстанавливался за ~15с).
# JARVIS_MQTT_RECONNECT_MIN=1
# JARVIS_MQTT_RECONNECT_MAX=15
