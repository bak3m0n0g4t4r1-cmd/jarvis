# Шаблон локальных настроек «Джарвиса». Скопируй в .env и заполни:
#   cp .env.example .env
# Файл .env в git НЕ попадает (см. .gitignore). config.py подхватывает его сам
# (load_dotenv), а для systemd «Мозг» получает его через EnvironmentFile.

# --- Casual-бэкенд: беседу ведёт облачный Gemini ---

# Ключ Google Gemini. Получить: https://aistudio.google.com/apikey
# Пустой ключ → беседа уходит в офлайн-фоллбэк (команды при этом работают как обычно).
GEMINI_API_KEY=

# Бэкенд бесед: gemini | local. local — без облака, только офлайн-фоллбэк.
JARVIS_CASUAL_BACKEND=gemini

# Имя модели Gemini. Версии меняются ежемесячно — сверь актуальное стабильное имя
# на момент установки (на 2026-06 стабильная flash-модель — gemini-3.5-flash).
JARVIS_GEMINI_MODEL=gemini-3.5-flash

# Grounding (модель сама ищет свежие факты: погода, курсы, новости): 1 — вкл, 0 — выкл.
JARVIS_GEMINI_GROUNDING=1

# Таймаут запроса к Gemini, секунды. Для grounding 5с маловато — дефолт 8с.
JARVIS_GEMINI_TIMEOUT=8

# Сколько реплик беседы (сообщений user/assistant) помнить и передавать в облако.
JARVIS_GEMINI_HISTORY=8
