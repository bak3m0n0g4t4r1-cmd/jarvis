# Шаблон локальных настроек «Джарвиса». Скопируй в .env и заполни:
#   cp .env.example .env
# Файл .env в git НЕ попадает (см. .gitignore). config.py подхватывает его сам
# (load_dotenv), а для systemd «Мозг» получает его через EnvironmentFile.

# --- Casual-бэкенд: беседу ведёт облачный Gemini ---

# Ключи Google Gemini (5 явных слотов). Получить: https://aistudio.google.com/apikey
# Ключи с РАЗНЫХ аккаунтов. При исчерпании квоты (429) Джарвис автоматически переключается
# на следующий непустой. Достаточно одного — остальные оставьте пустыми (это запас).
# Пустые все → беседа уходит в офлайн-фоллбэк (команды при этом работают как обычно).
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Бэкенд бесед: gemini | local. local — без облака, только офлайн-фоллбэк.
JARVIS_CASUAL_BACKEND=gemini

# Имя модели Gemini. Версии меняются ежемесячно — сверь актуальное стабильное имя
# на момент установки (на 2026-06 стабильная flash-модель — gemini-3.5-flash).
JARVIS_GEMINI_MODEL=gemini-3.5-flash

# Grounding (модель сама ищет свежие факты: погода, курсы, новости): 1 — вкл, 0 — выкл.
# У веб-поиска ОТДЕЛЬНАЯ жёсткая квота: при её исчерпании Джарвис сам отключает grounding
# на сессию и отвечает без свежих фактов (не уходит в офлайн) — можно смело держать вкл.
JARVIS_GEMINI_GROUNDING=1

# Бюджет «размышления» (thinking) Gemini в токенах. gemini-3.5-flash думает по умолчанию
# слишком долго — persona-запрос висел >40с и ловил таймаут; с 0 та же реплика приходит за
# ~2с. Дворецкому с короткими ответами размышление не нужно. 0 — ВЫКЛ (рекомендуется);
# >0 — ограничить; -1 — не задавать (для моделей без поддержки thinking).
JARVIS_GEMINI_THINKING_BUDGET=0

# Таймаут запроса к Gemini, секунды. Идёт через зарубежный прокси (лишний хоп). С thinking=0
# здоровый ответ ~2-3с, поэтому 20с покрывают и медленные ответы, и быстро ловят зависший
# запрос (троттл free-tier). Минимум API — 10с.
JARVIS_GEMINI_TIMEOUT=20

# Ретраи запроса к Gemini на ВРЕМЕННЫЕ сбои (503 перегрузка / 504 таймаут / обрыв):
# сколько ВСЕГО попыток на ОДИН ключ и базовая пауза (с, удваивается). 429 (квота)
# лечится НЕ ретраем, а переключением ключа. Бюджет ≈ таймаут × попытки — для голоса держим
# коротким (20с × 2 ≈ 40с худший случай перед фоллбэком).
# JARVIS_GEMINI_RETRIES=2
# JARVIS_GEMINI_RETRY_DELAY=1.0

# Сколько реплик беседы (сообщений user/assistant) помнить и передавать в облако.
JARVIS_GEMINI_HISTORY=8

# Прокси ТОЛЬКО для Gemini (обход геоблока). Пусто = напрямую. http:// или socks5://
# Затрагивает лишь облачный клиент; системный/пентест-трафик через прокси НЕ идёт.
# JARVIS_GEMINI_PROXY=http://логин:пароль@IP:ПОРТ

# --- Отказоустойчивость и логи (у всех есть разумные дефолты — можно не задавать) ---

# Порог логирования: INFO (дефолт) — чисто и по-человечески; DEBUG — со стек-трассами
# ожидаемых сбоёв (для разбора). Уровни видны во всех сервисах одинаково.
# JARVIS_LOG_LEVEL=INFO

# Heartbeat: раз в столько секунд сервис пишет в лог, что жив (INFO). 0 — выключить.
# JARVIS_HEARTBEAT_INTERVAL=300

# Автопереподключение к MQTT: backoff между попытками, секунды (потолок мал намеренно —
# чтобы после спящего режима/перезапуска брокера Джарвис восстанавливался за ~15с).
# JARVIS_MQTT_RECONNECT_MIN=1
# JARVIS_MQTT_RECONNECT_MAX=15

# Ретраи запроса к локальной модели (Ollama): сколько ВСЕГО попыток и базовая пауза (с).
# JARVIS_OLLAMA_RETRIES=2
# JARVIS_OLLAMA_RETRY_DELAY=1.0
