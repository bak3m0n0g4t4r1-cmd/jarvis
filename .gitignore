# Модели большие — в git не храним (откуда качать см. README)
models/*
!models/.gitkeep

# Логи и отчёты команд
logs/*
!logs/.gitkeep

# WAV-кэш синтезированной речи (Silero + JARVIS-DSP) — большой, пересобирается `jarvis tts build`
cache/

# Секреты и машинные правки: локальный оверрайд settings.yaml (ключи ламп Tuya и т.п.)
# — глубокий мёрдж поверх settings.yaml, в git НЕ попадает (см. jarvis/config.py).
settings.local.yaml
.env
.env.local

# Служебные файлы tinytuya (создаются сканом/мастером — не наши, в репо не нужны)
tinytuya.json
devices.json
snapshot.json
tuya-raw.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
