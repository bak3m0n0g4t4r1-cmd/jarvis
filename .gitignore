# Модели большие — в git не храним (откуда качать см. README)
models/*
!models/.gitkeep

# Логи и отчёты команд
logs/*
!logs/.gitkeep

# Секреты: ключ Gemini и прочие локальные настройки (шаблон — .env.example)
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
